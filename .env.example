# ── LLM（使用 OpenRouter，无需 OpenAI Key）─────────────────────────────
OPENAI_API_KEY=sk-or-v1-你的OpenRouter密钥
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-chat
LLM_TEMPERATURE=0.0

# ── Embedding（调用 API，与 LLM 使用同一套 Key 和 base_url）───────────
EMBEDDING_BACKEND=openai
# OpenRouter embedding 模型，可在 https://openrouter.ai/models 筛选 embeddings
EMBEDDING_MODEL=text-embedding-3-small

# ── RAG ────────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=data/vector_store
RESUME_DIR=data/resumes
RAG_TOP_K=5

# ── API 服务 ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── 数据库 ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hellojobs

# ── JWT 密钥 ───────────────────────────────────────────────────────────
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=把你的32字节Hex密钥粘贴在这里
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ── 种子用户 ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=你的管理员密码

# ── LangSmith 追踪（可选）──────────────────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=你的LangSmith密钥
# LANGSMITH_PROJECT=recruitment-agent
